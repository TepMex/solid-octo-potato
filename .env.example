# OpenAI-compatible VLM endpoint (see scripts/preprocess_vlm.py module docstring for venv + run steps)
BASE_URL=https://api.example.com/v1
API_TOKEN=your-api-token-here
MODEL=your-vision-model-name

# Optional overrides
# RAW_DATA_DIR=RawData
# OUTPUT_PATH=processed/tasks.jsonl
# REQUEST_TIMEOUT=120
# MAX_RETRIES=5

# Frontend (Bun build): public base for assets and data — same as your GitHub Pages URL for a project site, e.g.
# https://your-username.github.io/your-repo-name
# Defaults to / (site root) when unset. Override for GitHub Pages project URL, e.g.
# https://your-username.github.io/your-repo-name
# BASE_FRONTEND_URL=
